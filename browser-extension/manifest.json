{
  "manifest_version": 3,
  "name": "aria-reach — ARIA Accessibility Scanner",
  "version": "0.1.1",
  "description": "Scan pages for ARIA accessibility anti-patterns and identify likely component-library origins using DOM fingerprints.",
  "homepage_url": "https://github.com/manichandra/aria-reach",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "aria-reach",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting"]
}
