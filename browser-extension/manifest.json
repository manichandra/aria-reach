{
  "manifest_version": 3,
  "name": "aria-reach — ARIA anti-pattern scanner",
  "version": "0.1.0",
  "description": "Scan any page for the four ARIA anti-pattern classes and attribute findings to their likely upstream component library.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "aria-reach",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting"]
}
